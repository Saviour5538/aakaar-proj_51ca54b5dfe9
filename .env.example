# Connection string for the PostgreSQL database
DATABASE_URL=postgresql://username:password@localhost:5432/dbname

# Secret key for JWT authentication
JWT_SECRET=your_random_secret_key

# Port for the backend server
PORT=8000

# API URL for the frontend to communicate with the backend
VITE_API_URL=http://localhost:8000

# OpenAI API key for embeddings and generation
OPENAI_API_KEY=your_openai_api_key

# Anthropic API key (if applicable)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Pinecone API key (if applicable)
PINECONE_API_KEY=your_pinecone_api_key

# PostgreSQL URL for pgvector service
POSTGRES_URL=postgresql://username:password@localhost:5432/dbname